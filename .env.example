# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY & ANTHROPIC_API_KEY: Optional API keys for alternative LLM providers
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# LLM_PROVIDER: Selected provider ('gemini', 'openai', 'anthropic')
LLM_PROVIDER="gemini"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL & SUPABASE_ANON_KEY: Required for Supabase client & backend integration.
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# JWT_SECRET: Private signature key for user JWT authorization sessions.
JWT_SECRET="super-secret-interviewops-key-2026"

# OTEL_EXPORTER_OTLP_ENDPOINT: OpenTelemetry standard endpoint for span, metrics, and log ingestion.
# Pre-scaffolded for automated integration with SigNoz.
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_SERVICE_NAME="interviewops-api"

